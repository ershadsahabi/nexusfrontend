components:
  schemas:
    AnalysisCase:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        uuid:
          type: string
          format: uuid
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        name:
          type: string
          maxLength: 255
        description:
          type: string
        is_active:
          type: boolean
        metadata: {}
        project:
          type: integer
        analysis_model:
          type: integer
        load_case:
          type: integer
          nullable: true
        load_combination:
          type: integer
          nullable: true
      required:
      - analysis_model
      - created_at
      - id
      - name
      - project
